{
  "name": "onecx-parameter-ui",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "contributors": [
    "OneCX Development Team <onecx_dev@1000kit.org>"
  ],
  "config": {
    "openapiYaml": "src/assets/api/openapi-bff.yaml",
    "openapiOutput": "src/app/shared/generated"
  },
  "scripts": {
    "build": "ng build",
    "check": "ng lint --cache=true && npx prettier -c --cache .",
    "clean": "npm cache clean --force && ng cache clean && rm -rf *.log dist reports .angular .eslintcache ./node_modules/.cache/prettier/.prettier-cache",
    "lint": "ng lint --cache=true",
    "format": "ng lint --fix",
    "eslint": "eslint --quiet --ext .js,.ts src",
    "browser": "npx browserslist",
    "prepare": "husky || true",
    "start": "ng serve --configuration=development --proxy-config=proxy.conf.js",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "karma": "rm -rf reports && npm run test:ci",
    "sonar": "npx sonar-scanner",
    "apigen-cleanup": "rm -rf $npm_package_config_openapiOutput",
    "apigen-format": "npx prettier $npm_package_config_openapiYaml --write && npx prettier $npm_package_config_openapiOutput/**/* --write",
    "apigen-generate": "openapi-generator-cli generate -i $npm_package_config_openapiYaml -g typescript-angular -c apigen.yaml -o $npm_package_config_openapiOutput --type-mappings=AnyType=object,set=Array",
    "apigen": "npm run apigen-cleanup && npm run apigen-generate && npm run apigen-format"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "dependencies": {
    "@angular-architects/module-federation": "^20.0.0",
    "@angular/animations": "^20.3.26",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.26",
    "@angular/compiler": "^20.3.26",
    "@angular/core": "^20.3.26",
    "@angular/elements": "^20.3.26",
    "@angular/forms": "^20.3.26",
    "@angular/platform-browser": "^20.3.26",
    "@angular/platform-browser-dynamic": "^20.3.26",
    "@angular/router": "^20.3.26",
    "@ngneat/error-tailor": "^5.0.1",
    "@ngneat/until-destroy": "^10.0.0",
    "@ngrx/effects": "^20.1.0",
    "@ngrx/router-store": "^20.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@onecx/accelerator": "^7.12.0",
    "@onecx/angular-accelerator": "^7.12.0",
    "@onecx/angular-auth": "^7.12.0",
    "@onecx/angular-integration-interface": "^7.12.0",
    "@onecx/angular-remote-components": "^7.12.0",
    "@onecx/angular-standalone-shell": "^7.12.0",
    "@onecx/angular-testing": "^7.12.0",
    "@onecx/angular-utils": "^7.12.0",
    "@onecx/angular-webcomponents": "^7.12.0",
    "@onecx/integration-interface": "^7.12.0",
    "@primeng/themes": "^20.4.0",
    "@webcomponents/webcomponentsjs": "^2.8.0",
    "chart.js": "^4.5.1",
    "d3-scale-chromatic": "^3.1.0",
    "file-saver": "^2.0.5",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^20.4.0",
    "rxjs": "7.8.2",
    "ts-semaphore": "^1.0.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.32",
    "@angular-devkit/core": "^20.3.32",
    "@angular-devkit/schematics": "^20.3.32",
    "@angular-eslint/builder": "^20.7.0",
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/schematics": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/cli": "~20.3.32",
    "@angular/compiler-cli": "^20.3.26",
    "@angular/language-service": "^20.3.26",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.5.0",
    "@openapitools/openapi-generator-cli": "^2.18.4",
    "@schematics/angular": "^20.3.32",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~5.1.4",
